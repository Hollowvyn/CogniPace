{
  "name": "leetcode-spaced-repetition-extension",
  "version": "0.1.0",
  "private": true,
  "description": "LeetCode spaced repetition Chrome extension",
  "scripts": {
    "build": "node build.cjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "npm run test:logic",
    "typecheck": "tsc --noEmit",
    "test:logic": "node tests/run-tests.cjs"
  },
  "keywords": [
    "chrome-extension",
    "leetcode",
    "spaced-repetition"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.1.36",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "ts-fsrs": "^5.3.1"
  }
}
